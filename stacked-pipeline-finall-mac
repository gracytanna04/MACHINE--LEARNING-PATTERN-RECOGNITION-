def save_pipeline(pipeline: TwoLayerRespiratoryClassifier, save_dir: str, filename: str) -> str:
    path = os.path.join(save_dir, filename)
    with open(path, "wb") as f:
        pickle.dump(pipeline, f)
    print(f"\n[SAVE] Stacked pipeline saved → {path}")
    return path


def load_pipeline(pkl_path: str) -> TwoLayerRespiratoryClassifier:
    """
    Reload a previously saved TwoLayerRespiratoryClassifier.
    The class definitions (RespiratoryClassifier, EfficientNetRespiratory, etc.)
    must be importable, which they are if you run this script directly.
    """
    import __main__
    __main__.RespiratoryClassifier    = RespiratoryClassifier
    __main__.EfficientNetRespiratory  = EfficientNetRespiratory
    __main__.TwoLayerRespiratoryClassifier = TwoLayerRespiratoryClassifier

    with open(pkl_path, "rb") as f:
        pipeline = pickle.load(f)
    print(f"[LOAD] Stacked pipeline reloaded from {pkl_path}")
    return pipeline



def load_features(csv_path: str, id_col: str, label_col: str):
    """
    Load the feature CSV.

    Returns
    -------
    X         : pd.DataFrame  — feature matrix (no id, no label)
    y_binary  : pd.Series     — 0=healthy (disease==3), 1=diseased
    y_full    : pd.Series     — original integer labels
    ids       : pd.Series     — patient IDs
    """
    print(f"\n[DATA] Loading features: {csv_path}")
    df = pd.read_csv(csv_path)
    print(f"[DATA] Shape: {df.shape}")

    ids = df[id_col].copy() if id_col in df.columns else pd.Series(range(len(df)), name=id_col)

    if id_col in df.columns:
        df = df.drop(columns=[id_col])

    assert label_col in df.columns, f"Label column '{label_col}' not found in {csv_path}."

    y_full   = df[label_col].astype(int)
    y_binary = df[label_col].apply(lambda x: 0 if x == 3 else 1)   # healthy=3 → 0
    X        = df.drop(columns=[label_col])

    print(f"[DATA] Healthy (0): {(y_binary==0).sum()} | Diseased (1): {(y_binary==1).sum()}")
    return X, y_binary, y_full, ids


def load_audio_paths(csv_path: str) -> pd.DataFrame:
    """
    Load audio path CSV with at least ['id', 'cough_path', 'vowel_path'].
    Windows-style paths (E:\\...) are automatically translated to Mac paths
    using the WIN_TO_MAC_ROOTS mapping defined at the top of this file.
    """
    print(f"[DATA] Loading audio paths: {csv_path}")
    df = pd.read_csv(csv_path)
    for col in ("cough_path", "vowel_path"):
        assert col in df.columns, f"Column '{col}' not found in {csv_path}."
        df[col] = df[col].map(fix_path)
    print(f"[DATA] Audio entries: {len(df)}")
    print(f"[DATA] Example cough path: {df['cough_path'].iloc[0]}")
    print(f"[DATA] Example vowel path: {df['vowel_path'].iloc[0]}")
    return df



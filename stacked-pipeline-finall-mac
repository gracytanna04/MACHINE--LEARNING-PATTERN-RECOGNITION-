def fix_path(p: str) -> str:
    """
    Convert a Windows absolute path to its Mac equivalent.

    Steps
    -----
    1. Match the longest Windows root prefix in WIN_TO_MAC_ROOTS.
    2. Replace it with the corresponding Mac path.
    3. Flip all backslashes to forward slashes.

    If no Windows root is matched the path is returned unchanged
    (so Linux/Mac paths already in the CSV pass through safely).
    """
    if not isinstance(p, str):
        return p
    # Sort by length descending so longer prefixes are tried first
    for win_root in sorted(WIN_TO_MAC_ROOTS, key=len, reverse=True):
        if p.startswith(win_root):
            suffix   = p[len(win_root):]          # everything after the root
            mac_root = WIN_TO_MAC_ROOTS[win_root]
            return (mac_root + suffix).replace("\\", "/")
    # Not a known Windows root — just normalise backslashes in case
    return p.replace("\\", "/")



ALL_CLASSES = ["healthy", "asthma", "copd", "covid"]


def evaluate_pipeline_on_split(
    pipeline: TwoLayerRespiratoryClassifier,
    X_features_all: pd.DataFrame,
    y_full_all: pd.Series,
    ids_all: pd.Series,
    audio_df: pd.DataFrame,
    int_to_classname: dict,
    id_col: str = "id",
    split_name: str = "Validation",
    save_plots: bool = True,
    save_dir: str = ".",
):
    """
    Evaluate the stacked pipeline on one data split.

    Strategy
    --------
    - Feature CSV contains ALL patients (healthy + diseased).
    - Audio CSV contains only DISEASED patients (healthy rows were dropped).
    - Patients absent from the audio CSV are treated as healthy-only runs
      (Layer 1 is sufficient; Layer 2 skipped with dummy audio=None).

    Returns
    -------
    results_df : pd.DataFrame  — per-patient predictions
    metrics    : dict          — summary metrics
    """
    print(f"\n{'='*60}")
    print(f"EVALUATION — {split_name} Set")
    print(f"{'='*60}")

    # Build id → audio path lookup
    audio_lookup = {}
    if id_col in audio_df.columns:
        for _, row in audio_df.iterrows():
            audio_lookup[row[id_col]] = {
                "cough_path": row["cough_path"],
                "vowel_path": row["vowel_path"],
            }

    n_total = len(X_features_all)
    y_binary_all = y_full_all.apply(lambda x: 0 if x == 3 else 1)
    print(f"[EVAL] Total  : {n_total}")
    print(f"[EVAL] Healthy (GT): {(y_binary_all==0).sum()}")
    print(f"[EVAL] Diseased (GT): {(y_binary_all==1).sum()}")
    print(f"[EVAL] Running inference …")

    true_labels  = []
    pred_labels  = []
    layer1_probs = []
    t0 = time.time()

    for i in range(n_total):
        if i % 100 == 0:
            print(f"  [{i+1}/{n_total}] …")

        feature_row = X_features_all.iloc[i].values
        patient_id  = ids_all.iloc[i] if hasattr(ids_all, "iloc") else ids_all[i]
        true_int    = int(y_full_all.iloc[i])
        true_name   = int_to_classname.get(true_int, f"unknown({true_int})")

        audio_info  = audio_lookup.get(patient_id, None)

        result = pipeline.predict_single(
            feature_row    = feature_row,
            cough_wav_path = audio_info["cough_path"] if audio_info else None,
            vowel_wav_path = audio_info["vowel_path"] if audio_info else None,
        )

        true_labels.append(true_name)
        pred_labels.append(result["final_label"])
        layer1_probs.append(result["layer1_prob"])

    elapsed = time.time() - t0
    print(f"\n[EVAL] Done in {elapsed:.1f}s  ({elapsed/n_total:.3f}s/patient)")

    # ---- Build results DataFrame -------------------------------------------
    results_df = pd.DataFrame({
        "id"         : ids_all.values if hasattr(ids_all, "values") else ids_all,
        "true_label" : true_labels,
        "pred_label" : pred_labels,
        "layer1_prob": layer1_probs,
    })

    # ---- Metrics -----------------------------------------------------------
    acc      = accuracy_score(true_labels, pred_labels)
    prec_mac = precision_score(true_labels, pred_labels, average="macro",
                               labels=ALL_CLASSES, zero_division=0)
    rec_mac  = recall_score(true_labels, pred_labels, average="macro",
                            labels=ALL_CLASSES, zero_division=0)
    f1_mac   = f1_score(true_labels, pred_labels, average="macro",
                        labels=ALL_CLASSES, zero_division=0)
    cm       = confusion_matrix(true_labels, pred_labels, labels=ALL_CLASSES)

    print(f"\n  --- {split_name} Metrics (4-class, macro) ---")
    print(f"  Accuracy          : {acc:.4f}")
    print(f"  Precision (macro) : {prec_mac:.4f}")
    print(f"  Recall (macro)    : {rec_mac:.4f}   *** PRIMARY ***")
    print(f"  F1 (macro)        : {f1_mac:.4f}    *** PRIMARY ***")
    print(f"\n  --- Classification Report ---")
    print(classification_report(true_labels, pred_labels,
                                labels=ALL_CLASSES, zero_division=0))
    print(f"\n  --- Confusion Matrix (rows=True, cols=Predicted) ---")
    print(pd.DataFrame(cm, index=ALL_CLASSES, columns=ALL_CLASSES).to_string())

    wrong_at_l1 = results_df[(results_df["true_label"] == "healthy") &
                              (results_df["pred_label"] != "healthy")]
    wrong_at_l2 = results_df[(results_df["true_label"] != "healthy") &
                              (results_df["pred_label"] == "healthy")]
    print(f"\n  Layer 1 false positives (healthy→diseased): {len(wrong_at_l1)}")
    print(f"  Layer 1 false negatives (diseased→healthy): {len(wrong_at_l2)}")

    if save_plots:
        _plot_cm(cm, ALL_CLASSES, split_name, save_dir)

    metrics = {
        "accuracy"        : acc,
        "precision_macro" : prec_mac,
        "recall_macro"    : rec_mac,
        "f1_macro"        : f1_mac,
        "confusion_matrix": cm,
        "l1_fp_count"     : len(wrong_at_l1),
        "l1_fn_count"     : len(wrong_at_l2),
    }
    return results_df, metrics


def _plot_cm(cm, labels, split_name, save_dir):
    fig, ax = plt.subplots(figsize=(8, 6))
    sns.heatmap(cm, annot=True, fmt="d", cmap="Blues",
                xticklabels=labels, yticklabels=labels,
                ax=ax, linewidths=0.5, linecolor="gray")
    ax.set_xlabel("Predicted", fontsize=12)
    ax.set_ylabel("True", fontsize=12)
    ax.set_title(f"Stacked Pipeline — {split_name} Confusion Matrix", fontsize=13)
    plt.tight_layout()
    out = os.path.join(save_dir, f"StackedPipeline_{split_name}_CM.png".replace(" ", "_"))
    plt.savefig(out, dpi=150)
    print(f"[PLOT] Saved: {out}")
    plt.show()



import torchvision.models as tv_models
import torchvision.ops   as tv_ops


class EfficientNetRespiratory(nn.Module):
    """
    EfficientNet-B0 backbone adapted for single-channel (grayscale) mel-spectrogram input.
    Matches the architecture pickled inside inference_pipeline.pkl.
    """
    def __init__(self, num_classes: int = 3):
        super().__init__()
        base     = tv_models.efficientnet_b0(weights=None)
        # Patch first conv to accept 1-channel input
        old_conv = base.features[0][0]
        base.features[0][0] = nn.Conv2d(
            1, old_conv.out_channels,
            kernel_size=old_conv.kernel_size,
            stride=old_conv.stride,
            padding=old_conv.padding,
            bias=False,
        )
        self.backbone   = base.features
        self.avgpool    = base.avgpool
        self.classifier = nn.Sequential(
            nn.Dropout(p=0.2),
            nn.Linear(base.classifier[1].in_features, num_classes),
        )

    def forward(self, x):
        x = self.backbone(x)
        x = self.avgpool(x)
        x = x.flatten(1)
        return self.classifier(x)


class RespiratoryClassifier:
    """
    Thin wrapper around EfficientNetRespiratory that also stores the
    mel-spectrogram transform and inference helpers.
    This class must exist in the module namespace for unpickling to work.

    Attributes stored in the pickle (decoded from pkl binary):
        model       : EfficientNetRespiratory (nn.Module)
        i2l         : dict  {int → class_name}   e.g. {0:'asthma',1:'copd',2:'covid'}
        device      : torch.device
        dur         : float  clip duration in seconds
        img_size    : int    mel spectrogram height/width (if square-resized)
        sample_rate : int
        mel_transform / mel_spec / transform  (name may vary)
    """

    def __init__(self, model, mel_transform, i2l, device,
                 sample_rate=16000, dur=5.0, img_size=None):
        self.model        = model
        self.mel_transform= mel_transform   # torchaudio nn.Sequential
        self.i2l          = i2l             # idx → label string
        self.device       = device
        self.sample_rate  = sample_rate
        self.dur          = dur
        self.img_size     = img_size        # optional; may be None

    # -- audio helpers (also used by TwoLayerRespiratoryClassifier) ----------

    def _load_wav(self, wav_path: str) -> torch.Tensor:
        """Load .wav, mono-mix, resample, pad/trim to self.dur seconds."""
        try:
            waveform, sr = torchaudio.load(wav_path)
        except Exception:
            y, sr = librosa.load(wav_path, sr=None, mono=True)
            waveform = torch.tensor(y).unsqueeze(0)

        if waveform.shape[0] > 1:
            waveform = waveform.mean(dim=0, keepdim=True)

        if sr != self.sample_rate:
            waveform = T.Resample(orig_freq=sr, new_freq=self.sample_rate)(waveform)

        target = int(self.sample_rate * self.dur)
        cur    = waveform.shape[1]
        if cur < target:
            waveform = torch.nn.functional.pad(waveform, (0, target - cur))
        else:
            waveform = waveform[:, :target]
        return waveform

    def _to_spec(self, waveform: torch.Tensor) -> torch.Tensor:
        """Convert waveform → normalised mel-spectrogram."""
        spec = self.mel_transform(waveform)
        mean = spec.mean()
        std  = spec.std() + 1e-8
        return (spec - mean) / std

    def predict_from_paths(self, cough_path: str, vowel_path: str) -> str:
        """
        End-to-end Layer 2 inference from two .wav paths.
        Returns the predicted disease label string.
        """
        cough_spec = self._to_spec(self._load_wav(cough_path))   # [1, n_mels, T]
        vowel_spec = self._to_spec(self._load_wav(vowel_path))

        # Concatenate along time axis → [1, n_mels, 2*T], then add batch dim
        combined = torch.cat([cough_spec, vowel_spec], dim=2).unsqueeze(0)

        # Optional resize if img_size was set during training
        if self.img_size is not None:
            combined = torch.nn.functional.interpolate(
                combined, size=(self.img_size, self.img_size), mode="bilinear", align_corners=False
            )

        combined = combined.to(self.device)
        self.model.eval()
        with torch.no_grad():
            logits   = self.model(combined)
            pred_idx = torch.argmax(torch.softmax(logits, dim=1), dim=1).item()

        return self.i2l[pred_idx]

    def predict_proba_from_paths(self, cough_path: str, vowel_path: str) -> dict:
        """Returns {class_name: probability} dict."""
        cough_spec = self._to_spec(self._load_wav(cough_path))
        vowel_spec = self._to_spec(self._load_wav(vowel_path))
        combined   = torch.cat([cough_spec, vowel_spec], dim=2).unsqueeze(0)
        if self.img_size is not None:
            combined = torch.nn.functional.interpolate(
                combined, size=(self.img_size, self.img_size), mode="bilinear", align_corners=False
            )
        combined = combined.to(self.device)
        self.model.eval()
        with torch.no_grad():
            probs = torch.softmax(self.model(combined), dim=1)[0].cpu().numpy()
        return {self.i2l[i]: float(probs[i]) for i in range(len(probs))}



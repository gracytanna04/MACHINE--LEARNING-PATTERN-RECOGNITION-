class TwoLayerRespiratoryClassifier:
    """
    Stacked two-layer classifier for respiratory disease.

    Inference flow per patient
    --------------------------
    1. Layer 1 (XGBoost, 119 tabular features)
         → P(diseased)  ≥ threshold  →  diseased
         → else                      →  healthy  (Layer 2 skipped)
    2. Layer 2 (EfficientNet CNN, cough + vowel .wav)
         → asthma | copd | covid

    Final output: one of {healthy, asthma, copd, covid}
    """

    def __init__(
        self,
        layer1_model,            # fitted XGBClassifier
        layer2_classifier,       # RespiratoryClassifier instance
        layer1_threshold=0.5,
    ):
        self.layer1          = layer1_model
        self.layer2          = layer2_classifier
        self.layer1_threshold= layer1_threshold
        print("[PIPELINE] TwoLayerRespiratoryClassifier initialised.")
        print(f"[PIPELINE] Layer 1 threshold: {self.layer1_threshold}")

    # ---- single-patient inference ------------------------------------------

    def predict_single(
        self,
        feature_row,          # array-like, shape (119,)
        cough_wav_path=None,  # str path; required only when Layer 1 says diseased
        vowel_wav_path=None,
    ) -> dict:
        """
        Returns
        -------
        dict with keys:
            layer1_label  : 'healthy' | 'diseased'
            layer1_prob   : P(diseased) from XGBoost
            layer2_label  : 'asthma'|'copd'|'covid'|None
            final_label   : 4-class string label
        """
        X             = np.array(feature_row).reshape(1, -1)
        diseased_prob = float(self.layer1.predict_proba(X)[0, 1])
        is_diseased   = diseased_prob >= self.layer1_threshold

        if not is_diseased:
            return {
                "layer1_label": "healthy",
                "layer1_prob" : diseased_prob,
                "layer2_label": None,
                "final_label" : "healthy",
            }

        # Layer 2
        if cough_wav_path is None or vowel_wav_path is None:
            # No audio available for a patient Layer 1 flagged as diseased
            return {
                "layer1_label": "diseased",
                "layer1_prob" : diseased_prob,
                "layer2_label": "unknown_diseased",
                "final_label" : "unknown_diseased",
            }

        disease_label = self.layer2.predict_from_paths(cough_wav_path, vowel_wav_path)
        return {
            "layer1_label": "diseased",
            "layer1_prob" : diseased_prob,
            "layer2_label": disease_label,
            "final_label" : disease_label,
        }

    # ---- batch inference ---------------------------------------------------

    def predict_batch(self, X_features: pd.DataFrame, audio_df: pd.DataFrame) -> list:
        """
        Parameters
        ----------
        X_features : pd.DataFrame  — feature matrix (no id/label cols), row-aligned
        audio_df   : pd.DataFrame  — must have 'cough_path', 'vowel_path' columns,
                                     row-aligned with X_features

        Returns
        -------
        list of result dicts (one per patient)
        """
        results = []
        n       = len(X_features)
        for i in range(n):
            if i % 50 == 0:
                print(f"  [BATCH] Patient {i+1}/{n} ...")
            result = self.predict_single(
                feature_row    = X_features.iloc[i].values,
                cough_wav_path = audio_df.iloc[i]["cough_path"],
                vowel_wav_path = audio_df.iloc[i]["vowel_path"],
            )
            results.append(result)
        return results



def load_layer1(path: str) -> XGBClassifier:
    """Load the XGBoost Layer 1 model (stored in .ubj / JSON format)."""
    model = XGBClassifier()
    model.load_model(path)
    print(f"[LOAD] Layer 1 XGBoost loaded  — {model.n_features_in_} features, "
          f"classes: {model.classes_}")
    return model


def load_layer2(pkl_path: str, device: torch.device) -> "RespiratoryClassifier":
    """
    Unpickle the RespiratoryClassifier.
    RespiratoryClassifier and EfficientNetRespiratory must be defined in this
    module's namespace before calling this function (they are, see Section 2).
    """
    # Inject the classes into __main__ so pickle can resolve them
    import __main__
    __main__.RespiratoryClassifier    = RespiratoryClassifier
    __main__.EfficientNetRespiratory  = EfficientNetRespiratory

    with open(pkl_path, "rb") as f:
        clf = pickle.load(f)

    # Move model to the target device
    clf.model  = clf.model.to(device)
    clf.device = device
    clf.model.eval()

    # Normalise attribute name for mel transform (pkl may use different names)
    for attr in ("mel_transform", "mel_spec", "transform", "spectrogram"):
        if hasattr(clf, attr) and getattr(clf, attr) is not None:
            clf.mel_transform = getattr(clf, attr)
            break

    print(f"[LOAD] Layer 2 CNN (EfficientNet) loaded  — "
          f"classes: {list(clf.i2l.values())}")
    return clf


def build_stacked_pipeline(
    layer1_path: str,
    layer2_pkl_path: str,
    device: torch.device,
    layer1_threshold: float = 0.5,
) -> TwoLayerRespiratoryClassifier:
    layer1 = load_layer1(layer1_path)
    layer2 = load_layer2(layer2_pkl_path, device)
    pipeline = TwoLayerRespiratoryClassifier(
        layer1_model      = layer1,
        layer2_classifier = layer2,
        layer1_threshold  = layer1_threshold,
    )
    return pipeline


